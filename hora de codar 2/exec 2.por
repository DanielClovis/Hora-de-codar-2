programa {
  funcao inicio() {
    real numero

    escreva("escreva um numero! ")
    leia(numero)


    se(numero > 0){
      escreva("esse numero é positivo! ")
    }
    senao se(numero < 0){
      escreva("esse numero é negativo! ")
    }

    senao{
      escreva("esse numero é zero")
    }

    
   
  }
}
